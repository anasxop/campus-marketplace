# ─── Backend (Render) ────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campus-place?retryWrites=true&w=majority

# Google OAuth (server-side token verification)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend email service
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified sender in your Resend account (not onboarding@resend.dev for production)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Your Vercel frontend URL — used in password-reset email links
FRONTEND_URL=https://your-app.vercel.app

# Your Vercel frontend URL — used for CORS (must match FRONTEND_URL exactly)
CLIENT_URL=https://your-app.vercel.app

# ─── Frontend (Vercel) ────────────────────────────────────────────────────────

# Your Render backend URL (no trailing slash)
VITE_API_URL=https://campus-marketplace-api.onrender.com

# Google OAuth (client-side button rendering)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cloudinary image uploads
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
